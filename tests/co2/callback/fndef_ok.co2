//@ mode: co2
//@ run-status: 0

use std::option::Option;
use std::range::Range;
use std::vec::Vec;

#include <assert.h>

fn triple(x: i32) -> i32 {
    return x * 3;
}

fn triple_ref(x: &i32) -> i32 {
    return *x * 3;
}

fn triple_ptr(x: *mut i32) -> i32 {
    return *x * 3;
}

fn is_even_ref(x: &i32) -> bool {
    return *x % 2 == 0;
}

fn main() {
    Option::<i32> x = Option::<i32>::Some(5);
    assert(x.unwrap() == 5);

    Option::<i32> y = x.map(triple);
    assert(y.unwrap() == 15);

    Option::<&i32> z1 = y.as_ref();
    Option::<i32> z2 = z1.map(triple_ref);

    assert(z2.unwrap() == 45);

    Range::<i32> r = { .start = 1, .end = 10 };
    // assert(r.into_iter().any(is_even_ref));

    Vec::<i32> v = r.into_iter().collect::<Vec<i32>>();
    v.sort_by_key(triple_ref);
}
