//@ mode: co2
//@ run-status: 0

#include <assert.h>
#include <stddef.h>

pub struct ReprRust {
    field1: u16,
    field2: u32,
    field3: u16,
}

#[repr(C)]
pub struct ReprC {
    field1: u16,
    field2: u32,
    field3: u16,
}

#[repr(C, packed)]
pub struct ReprPacked {
    field1: u16,
    field2: u32,
    field3: u16,
}

fn main() {
    assert(sizeof(ReprRust) == 8);
    if (offsetof(ReprRust, field2) == 0) {
        if (offsetof(ReprRust, field1) == 4) {
            assert(offsetof(ReprRust, field3) == 6);            
        } else {
            assert(offsetof(ReprRust, field3) == 4);
            assert(offsetof(ReprRust, field1) == 6);
        }
    } else {
        assert(offsetof(ReprRust, field2) == 4);
        if (offsetof(ReprRust, field1) == 2) {
            assert(offsetof(ReprRust, field3) == 0);            
        } else {
            assert(offsetof(ReprRust, field3) == 2);
            assert(offsetof(ReprRust, field1) == 0);
        }
    }

    assert(sizeof(ReprC) == 12);
    assert(offsetof(ReprC, field1) == 0);    
    assert(offsetof(ReprC, field2) == 4);    
    assert(offsetof(ReprC, field3) == 8);    

    assert(sizeof(ReprPacked) == 8);
    assert(offsetof(ReprPacked, field1) == 0);    
    assert(offsetof(ReprPacked, field2) == 2);    
    assert(offsetof(ReprPacked, field3) == 6);
}
