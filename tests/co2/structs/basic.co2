//@ mode: co2
//@ run-status: 0

use std::range::Range;

#include <assert.h>
#include <stddef.h>

pub struct St {
    field1: u16,
    field2: i32,
    field3: u16,
}

fn main() {
    St st1 = { .field1 = 1, .field2 = 5, .field3 = 2 };
    assert(st1.field1 == 1);
    assert(st1.field2 == 5);
    assert(st1.field3 == 2);

    Range::<i32> r1 = { .start = 2, .end = 6 };
    assert(r1.contains(&st1.field2));
}
