mod nested;
mod ffi;

mod tests {
    #include <assert.h>

    int helper() {
        return 0;
    }

    #[test]
    fn test_something() {
        assert(helper() == 0);
    }
}

/// Target for single-segment function links.
pub fn link_target() -> i32 {
    return 1;
}

/// Type alias for link tests.
