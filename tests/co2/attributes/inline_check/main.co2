// Short functions (returning constants) — all inlined at -O2 regardless of attr

#[no_mangle]
#[inline(never)]
fn never_short() -> i32 {
    return 42;
}

#[no_mangle]
#[inline(always)]
fn always_short() -> i32 {
    return 43;
}

#[no_mangle]
#[inline]
fn hint_short() -> i32 {
    return 44;
}

#[no_mangle]
fn noattr_short() -> i32 {
    return 45;
}

fn main() {
    if (never_short() != 42) {
        std::process::exit(1);
    }
    if (always_short() != 43) {
        std::process::exit(2);
    }
    if (hint_short() != 44) {
        std::process::exit(3);
    }
    if (noattr_short() != 45) {
        std::process::exit(4);
    }
}
