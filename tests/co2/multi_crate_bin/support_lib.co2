} ComplexStruct;

long long int HUGE_LONG = 0xabcd00000000;

typedef struct {
    int a;
    char b;
    char c;
    int d;
} NormalReprCStruct;

typedef struct {
    int a;
    int b : 1;
    int c : 1;
    int d : 1;
    int e;
} BitFieldReprCStruct;

pub struct ReprRustStruct {
    a: i32,
    b: *mut i32,
    c: *const i32,
    d: NormalReprCStruct,
    e: BitFieldReprCStruct,
    f: *mut BitFieldReprCStruct,
}

pub struct RustStructHoldingVector {
    a: i32,
    b: Vec<i32>,
    c: Vec<RustStructHoldingVector>,
}

#[derive(Copy)]
pub struct CopyReprRustStruct {
    a: i32,
    b: Point,
    c: *mut CopyReprRustStruct,
    foo: *const RustStructHoldingVector,
}

