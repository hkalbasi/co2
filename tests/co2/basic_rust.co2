//@ mode: co2
//@ run-status: 0

use std::f64::consts::PI;
use std::time::Instant;
use std::time::Duration;
use std::thread;
use std::vec::Vec;
use std::mem::drop;

typedef Instant MyInstant;
typedef Vec<i32> MyVec;

fn vec_vec_consumer(vv: Vec<Vec<i32>>) {
    Vec::<Vec<Vec<i32>>> vvv = Vec::<Vec<Vec<i32>>>::new();
    vvv.push(vv);
    drop(vvv);
}

fn main() {
    if (PI < 3.14 || std::f64::consts::PI > 3.15) {
        std::process::exit(1);
    }

    Instant instant = Instant::now();
    thread::sleep(Duration::from_millis(10));
    Duration dur = instant.elapsed();
    if (dur.as_millis() < 5 || Duration::as_millis(&dur) > 50) {
        std::process::exit(2);
    }

    Instant instant2 = MyInstant::now();
    MyInstant instant3 = instant2;
    (void)instant3;

    MyVec v = Vec::<i32>::new();
    Vec<i32> v2 = MyVec::new();
    v.push(2);
    v.push(5);
    v.push(7);
    float value = 3.1;
    v.push(value); // C casts still work
    if (v.len() != 4) {
        std::process::exit(3);
    }
    if (v.pop().unwrap() != 3) {
        std::process::exit(3);
    }
    usize one_usize = 1;
    if (*v.get(one_usize).unwrap() != 5) {
        std::process::exit(3);    
    }
    if (*v.get_unchecked(one_usize) != 5) {
        std::process::exit(3);    
    }
    if (*v.get(1_usize).unwrap() != 5) {
        std::process::exit(3);    
    }
    if (*v.get((usize)1).unwrap() != 5) {
        std::process::exit(3);    
    }
    if (*v.get::<usize>(1).unwrap() != 5) {
        std::process::exit(3);    
    }

    Vec<Vec<i32> > vv = Vec::<Vec<i32> > ::new();
    vv.push(v);
    vv.push(v2);
    if (vv.len() != 2) {
        std::process::exit(3);
    }

    i32 a = 2, b = 5;
    std::ptr::swap::<i32>(&a, &b);

    if (a != 5 || b != 2) {
        std::process::exit(4);
    }

    Vec<*mut i32> v3 = Vec::<*mut i32>::new();
    v3.push(&a);
    v3.push(&b);
    if (*v3.pop().unwrap() != 2) {
        std::process::exit(5);
    }
    if (*v3.pop().unwrap() != 5) {
        std::process::exit(5);
    }
}
