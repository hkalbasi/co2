//@ mode: co2
//@ run-status: 0
//@ run-stdout: co2\n

int write(int fd, char* buf, int len);

fn fibo(n: i32) -> i32 {
    i32 a = 0, b = 1;
    for (i32 i = 0; i < n; i += 1) {
        b = a + b;
        a = b - a;
    }
    return b;
}

fn fill_buf(buf: *mut u8) {
    buf[0] = 'c';
    buf[1] = 'o';
    buf[2] = '2';
    buf[3] = '\n';
}

fn main() {
    if (fibo(6) == 13) {
        u8 ar[10] = {};
        fill_buf(ar);
        write(1, ar, 4);
    }
}
