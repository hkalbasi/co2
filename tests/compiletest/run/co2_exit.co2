//@ mode: co2
//@ run-status: 0
//@ run-stdout: CO2\n

int write(int fd, char* buf, int len);

fn fibo(n: i32) -> i32 {
    i32 a = 0, b = 1;
    for (i32 i = 0; i < n; i += 1) {
        b = a + b;
        a = b - a;
    }
    return b;
}

#define END_LINE '\n'

pub fn fill_buf(buf: *mut u8) {
    buf[0] = 'c';
    buf[1] = 'o';
    buf[2] = '2';
    buf[3] = END_LINE;
    buf[4] = 0;
}

type BufPtr = *mut u8;

void capitalize_buf(BufPtr buf) {
    int i = 0;
    while (buf[i] != '\0') {
        if (buf[i] >= 'a' && buf[i] <= 'z') {
            buf[i] -= 'a' - 'A';
        }
        i += 1;
    }
}

fn main() {
    if (fibo(6) == 13) {
        u8 ar[10] = {};
        fill_buf(ar);
        capitalize_buf(ar);
        write(1, ar, 4);
    }
}
