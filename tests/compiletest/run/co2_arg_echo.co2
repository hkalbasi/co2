//@ mode: co2
//@ run-status: 0
//@ run-args: hello-arg
//@ run-stdout: hello-arg

use std::env::Args;
use std::iter::Iterator;
use std::option::Option;
use std::string::String;
use std::vec::Vec;

int write(int, u8*, usize);

fn main() {
    Args args = std::env::args();
    args.next(); // Skip program name
    Option<String> opt = args.next();
    String arg = opt.unwrap();
    usize len = arg.len();
    Vec<u8> bytes = arg.into_bytes();
    u8* ptr = bytes.as_mut_ptr();
    write(1, ptr, len);
}
