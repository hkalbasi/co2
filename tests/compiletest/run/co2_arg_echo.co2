//@ mode: co2
//@ run-status: 0
//@ run-args: hello-arg
//@ run-stdout: hello-arg

use std::env::args;
use std::iter::Iterator;

int write(int, u8*, usize);

void main() {
    std::env::Args args = std::env::args();
    core::option::Option<alloc::string::String> skip0 = std::iter::Iterator<std::env::Args>::next(args);
    core::option::Option<alloc::string::String> opt = std::iter::Iterator<std::env::Args>::next(args);
    alloc::string::String arg = core::option::Option<alloc::string::String>::unwrap(opt);
    usize len = std::string::String::len(arg);
    alloc::vec::Vec<u8> bytes = std::string::String::into_bytes(arg);
    u8* ptr = alloc::vec::Vec<u8>::as_mut_ptr(bytes);
    write(1, ptr, len);
}
